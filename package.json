{
  "name": "@linhey/react-debug-inspector",
  "version": "1.2.3",
  "description": "A developer tool to inspect React components in browser and jump to source code.",
  "author": "linhey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/linhay/react-debug-inspector"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.mjs",
      "require": "./dist/browser.js",
      "default": "./dist/browser.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts src/browser.ts --format cjs,esm --watch --dts",
    "dev:test-app": "vite --config vite.config.test.ts",
    "build": "tsup src/index.ts src/browser.ts --format cjs,esm --dts --clean --external @babel/core",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "record:demo": "playwright test e2e/demo-recording.spec.ts --config playwright.demo.config.ts",
    "record:demo:headed": "playwright test e2e/demo-recording.spec.ts --config playwright.demo.config.ts --headed",
    "test:all": "npm run test && npm run test:e2e",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@babel/core": "^7.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^26.1.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "keywords": [
    "react",
    "debug",
    "inspector",
    "vite",
    "babel-plugin"
  ]
}
